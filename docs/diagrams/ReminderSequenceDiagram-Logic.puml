@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "m:ReminderCommand" as ReminderCommand LOGIC_COLOR
participant ":ReminderHighlightState" as ReminderHighlightState LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute(reminder)
activate LogicManager

LogicManager -> AddressBookParser : parseCommand(reminder)
activate AddressBookParser

create ReminderCommand
AddressBookParser -> ReminderCommand
activate ReminderCommand

ReminderCommand --> AddressBookParser
deactivate ReminderCommand

AddressBookParser --> LogicManager : m
deactivate AddressBookParser

LogicManager -> ReminderCommand : execute()
activate ReminderCommand

ReminderCommand -> ReminderHighlightState : setEnabled(true)
activate ReminderHighlightState
ReminderHighlightState --> ReminderCommand
deactivate ReminderHighlightState

ReminderCommand -> Model : getUserPrefs()
activate Model
Model --> ReminderCommand : userPrefs
deactivate Model

ReminderCommand -> Model : setUserPrefs(updatedPrefs)
activate Model
Model --> ReminderCommand
deactivate Model

ReminderCommand -> Model : updateSortedApplicationList(byDeadlineComparator)
activate Model
Model --> ReminderCommand
deactivate Model

ReminderCommand -> Model : commitAddressBook()
activate Model
Model --> ReminderCommand
deactivate Model

ReminderCommand --> LogicManager : result
deactivate ReminderCommand
ReminderCommand -[hidden]-> LogicManager : result
destroy ReminderCommand

[<--LogicManager
deactivate LogicManager
@enduml
