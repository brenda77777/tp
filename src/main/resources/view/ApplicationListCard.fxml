<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="card-pane" spacing="10" alignment="CENTER_LEFT">

  <VBox spacing="5" HBox.hgrow="ALWAYS">

    <HBox spacing="8" alignment="CENTER_LEFT">
      <Label fx:id="id"   styleClass="cell-id" />
      <Label fx:id="role" styleClass="cell-role-name" />
    </HBox>

    <Label fx:id="deadline" styleClass="deadline-label" />

    <FlowPane fx:id="tags" hgap="6" vgap="4" />

    <VBox fx:id="detailsBox" spacing="4" />

  </VBox>

  <padding>
    <Insets top="10" right="16" bottom="10" left="16" />
  </padding>

</HBox>
